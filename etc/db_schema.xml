<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="market_gift_card" resource="default" engine="innodb" comment="Gift Card Table">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID"/>

        <column xsi:type="int" name="assigned_customer_id" padding="10" unsigned="true" nullable="true" comment="Customer ID"/>

        <column xsi:type="varchar" name="code" length="255" nullable="false" comment="Gift Card Code"/>
        <column xsi:type="int" name="status" unsigned="true" nullable="false" comment="Status"/>

        <column xsi:type="decimal" name="initial_value" scale="4" precision="12" unsigned="true" nullable="true" comment="Initial Value"/>
        <column xsi:type="decimal" name="current_value" scale="4" precision="12" unsigned="true" nullable="true" comment="Current Value"/>


        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>
        <column xsi:type="timestamp" name="updated_at" on_update="true" nullable="false" default="CURRENT_TIMESTAMP" comment="Updated At"/>

        <column xsi:type="varchar" name="recipient_email" length="255" nullable="false" comment="Recipient email"/>
        <column xsi:type="varchar" name="recipient_name" length="255" nullable="false" comment="Recipient name"/>

        <constraint xsi:type="foreign" referenceId="GIFT_CARD_ASSIGNED_CUSTOMER_ID_CUSTOMER_ENTITY_ENTITY_ID"
                    table="market_gift_card" column="assigned_customer_id" referenceTable="customer_entity"
                    referenceColumn="entity_id" onDelete="CASCADE"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>

    <table name="market_gift_card_usage" resource="default" engine="innodb" comment="Gift Card Table">
        <column xsi:type="int" name="id" padding="10" unsigned="true" nullable="false" identity="true" comment="ID"/>

        <column xsi:type="int" name="gift_card_id" padding="10" unsigned="true" nullable="false" comment="Gift Card ID"/>
        <column xsi:type="int" name="order_id" padding="10" unsigned="true" nullable="false" comment="Order ID"/>
        <column xsi:type="decimal" name="value_change" scale="6" precision="20" unsigned="true" nullable="false" comment="Amount Used"/>

        <column xsi:type="text" name="notes" nullable="true" comment="Notes"/>

        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP" comment="Created At"/>

        <constraint xsi:type="foreign" referenceId="GIFT_CARD_HISTORY_GIFT_CARD_ID_MARKET_GIFT_CARD_ID"
                    table="market_gift_card_usage" column="gift_card_id" referenceTable="market_gift_card"
                    referenceColumn="id" onDelete="CASCADE"/>

        <constraint xsi:type="foreign" referenceId="GIFT_CARD_HISTORY_ORDER_ID_SALES_ORDER_ENTITY_ENTITY_ID"
                    table="market_gift_card_usage" column="order_id" referenceTable="sales_order"
                    referenceColumn="entity_id" onDelete="CASCADE"/>

        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="id"/>
        </constraint>
    </table>

</schema>
